# =======================================================
# BACKEND (PYTHON / DJANGO)
# =======================================================
__pycache__/
*.py[cod]
*$py.class
*.log
*.pot

# Entornos Virtuales
venv/
env/
.venv/
.env

# Base de datos local (Nunca subir SQLite si se usara)
db.sqlite3
db.sqlite3-journal

# Carpetas de medios y estáticos locales
media/
staticfiles/
/static/

# =======================================================
# FRONTEND (REACT / VITE / NODE)
# =======================================================
# Dependencias (Pesadas - Nunca subir)
node_modules/

# Logs de instalación (Basura)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Builds de Producción (Lo que genera npm run build)
dist/
dist-ssr/

# Archivos de entorno locales (Vite genera estos a veces)
*.local

# =======================================================
# 🔒 SEGURIDAD Y SECRETOS (CRÍTICO)
# =======================================================
# Archivos que contienen contraseñas reales
.env
.env.prod
.env.production
portal_web/.env

# =======================================================
# 🛠️ EDITORES E IDEs (VS Code, Visual Studio, Mac, etc.)
# =======================================================
.DS_Store
Thumbs.db
.idea/

# VS Code
.vscode/*
!.vscode/extensions.json

# Visual Studio (Archivos que tenías en tu lista)
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =======================================================
# KIRO IDE (Archivos de configuración local)
# =======================================================
.kiro/
